9:["$","section",null,{"className":"componentGrid","children":[["$","article","SlotWatcher",{"className":"component","children":[["$","h3",null,{"children":"SlotWatcher"}],["$","p",null,{"children":"Streams slots through Yellowstone gRPC first, then WSS, then HTTP polling. Resolves leader windows through RPC when gRPC emits slots before leader cache is ready."}]]}],["$","article","TipMonitor",{"className":"component","children":[["$","h3",null,{"children":"TipMonitor"}],["$","p",null,{"children":"Samples live Jito tip levels and keeps percentile context so tips are selected from observed market pressure, not hardcoded constants."}]]}],["$","article","PulseScore",{"className":"component","children":[["$","h3",null,{"children":"PulseScore"}],["$","p",null,{"children":"Combines slot health, tip pressure, and leader reliability into one execution temperature. It is a decision input, not a magic truth source."}]]}],["$","article","AI Layer",{"className":"component","children":[["$","h3",null,{"children":"AI Layer"}],["$","p",null,{"children":"Single-agent or consensus mode. Execution AI decides SUBMIT/HOLD; Diagnostic AI decides RETRY/SKIP only for real failed transaction payloads."}]]}],["$","article","BundleBuilder",{"className":"component","children":[["$","h3",null,{"children":"BundleBuilder"}],["$","p",null,{"children":"Builds versioned SOL/SPL transfer bundles with Jito tip transfer included atomically. Every retry gets a fresh blockhash."}]]}],["$","article","JitoSubmitter",{"className":"component","children":[["$","h3",null,{"children":"JitoSubmitter"}],["$","p",null,{"children":"Submits bundles, tracks inflight status, follows landed bundles to confirmed/finalized, and enriches failures with chain context."}]]}],["$","article","StateManager",{"className":"component","children":[["$","h3",null,{"children":"StateManager"}],["$","p",null,{"children":"Maintains live network state, leader reliability, bundle lifecycle state, failed payload archive, and snapshot persistence."}]]}],["$","article","LifecycleLedger",{"className":"component","children":[["$","h3",null,{"children":"LifecycleLedger"}],["$","p",null,{"children":"Append-only JSONL audit log for decisions, holds, submissions, failures, transitions, and run summaries."}]]}]]}]
