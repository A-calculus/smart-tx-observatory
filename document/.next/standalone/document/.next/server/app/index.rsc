c:["$","div",null,{"className":"sectionTitle","children":[["$","p",null,{"children":"AI Behavior"}],["$","h2",null,{"children":"What the agent demonstrated"}]]}]
d:["$","section",null,{"className":"grid three","children":[["$","article",null,{"className":"panel","children":[["$","h3",null,{"children":"Failure Reasoning"}],["$","div",null,{"children":["$","p",null,{"children":["The agent learned from Jito statuses, but raw ",["$","code",null,{"children":"Invalid"}]," was not enough. The backend now enriches failures with signature status, blockhash validity, sender balance, tip market, and leader window before the diagnostic prompt."]}]}]]}],["$","article",null,{"className":"panel","children":[["$","h3",null,{"children":"Tip Selection"}],["$","div",null,{"children":["$","p",null,{"children":"The agent did not use a fixed priority fee. It used live p50/p90 tip levels: median when conditions were acceptable, p90 when retrying after repeated invalid bundle states."}]}]]}],["$","article",null,{"className":"panel","children":[["$","h3",null,{"children":"Submission Timing"}],["$","div",null,{"children":["$","p",null,{"children":"The agent held a transaction for 5 slots when pulse score and slot health were degraded, then submitted after rotation. That shows timing awareness, not just retry-on-error behavior."}]}]]}]]}]
e:["$","div",null,{"className":"sectionTitle","children":[["$","p",null,{"children":"Failure Strategy"}],["$","h2",null,{"children":"Captured and classified states"}]]}]
f:["$","section",null,{"className":"strategy","children":[["$","div",null,{"className":"decisionTree","children":[["$","div",null,{"className":"branch root","children":"Bundle status"}],["$","div",null,{"className":"branch","children":"Pending → keep polling"}],["$","div",null,{"className":"branch","children":"Landed → watch signature"}],["$","div",null,{"className":"branch good","children":"Confirmed / Finalized → success"}],["$","div",null,{"className":"branch warn","children":"Invalid → collect chain context"}],["$","div",null,{"className":"branch bad","children":"Failed / On-chain err → classify failure"}],["$","div",null,{"className":"branch","children":"Diagnostic AI → RETRY only with payload"}]]}],["$","article",null,{"className":"panel","children":[["$","h3",null,{"children":"Why this matters"}],["$","div",null,{"children":["$","p",null,{"children":"Solana failure modes are not all equal. A skipped leader is a network observation. An expired blockhash is a rebuild problem. A Jito `Invalid` status is a tracking/execution ambiguity. A signature error is an on-chain execution failure. Treating all of these as the same retry is how bots waste tips and hide bugs."}]}]]}]]}]
10:["$","div",null,{"className":"sectionTitle","children":[["$","p",null,{"children":"CTO Questions"}],["$","h2",null,{"children":"Answers from the running system"}]]}]
11:["$","section",null,{"className":"grid three qa","children":[["$","article",null,{"className":"panel","children":[["$","h3",null,{"children":"1. processed_at vs confirmed_at delta"}],["$","div",null,{"children":["$","p",null,{"children":"The delta shows how long the cluster took to move from execution in a produced block to stronger vote confirmation. In the successful run, processed happened at 2,647ms and confirmed at 4,876ms from submission, so the processed-to-confirmed gap was about 2.2 seconds. A small gap suggests votes propagated normally; a widening gap suggests slower confirmation, fork uncertainty, skipped leaders, or validator/vote lag."}]}]]}],["$","article",null,{"className":"panel","children":[["$","h3",null,{"children":"2. Why not finalized blockhash?"}],["$","div",null,{"children":["$","p",null,{"children":"A time-sensitive transaction needs a fresh recent blockhash. Fetching at finalized waits for maximum commitment and gives you an older blockhash, burning useful validity window before you even sign and submit. Use processed or confirmed for current blockhashes, then track confirmation separately after submission."}]}]]}],["$","article",null,{"className":"panel","children":[["$","h3",null,{"children":"3. If the Jito leader skips?"}],["$","div",null,{"children":["$","p",null,{"children":"If the leader responsible for the target slot skips, the bundle cannot land in that skipped block. It may remain pending briefly, become invalid or disappear from Jito tracking, or require resubmission with a fresh blockhash and updated tip. CHRONOS records the skip as leader reliability data; it only retries if an actual submitted bundle failed and payload exists."}]}]]}]]}]
