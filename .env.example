# ============================================================
# CHRONOS Observatory — Environment Configuration
# Region: Frankfurt, Germany (FRA) throughout this project
# ============================================================

# -----------------------------------------------------------
# Testnet RPC/WSS defaults.
# Public Solana Testnet endpoints do not need an API key.
# If you switch RPC_BASE_URL/WS_BASE_URL to Solinfra, set SOLINFRA_API_KEY
# or RPC_BASE_API_KEY/WS_BASE_API_KEY.
# -----------------------------------------------------------
RPC_BASE_URL=https://api.testnet.solana.com
WS_BASE_URL=wss://api.testnet.solana.com
# Solinfra gRPC uses the token as Yellowstone x-token metadata.
# Only enable when this endpoint is confirmed to be on Solana Testnet.
GRPC_BASE_URL=https://fra.grpc.solinfra.dev:443
GRPC_BASE_TOKEN=
GRPC_CLUSTER=

# Optional provider-specific fallbacks.
# Chainstack core endpoints may use CHAINSTACK_API_KEY, but your current
# Chainstack endpoint is Devnet and must not be mixed with Jito Testnet.
CHAINSTACK_API_KEY=
SOLINFRA_API_KEY=
RPC_URL=https://fra.rpc.solinfra.dev/sol
WS_URL=wss://solana-mainnet.core.chainstack.com
GRPC_URL=https://fra.grpc.solinfra.dev:443
GRPC_TOKEN=

#https://api.testnet.solana.com
#wss://api.testnet.solana.com

# -----------------------------------------------------------
# Jito Block Engine Settings
# Testnet: https://testnet.block-engine.jito.wtf (no regional variant)
# Mainnet Frankfurt: https://frankfurt.mainnet.block-engine.jito.wtf
# -----------------------------------------------------------
JITO_BLOCK_ENGINE_URL=https://testnet.block-engine.jito.wtf

# -----------------------------------------------------------
# Multi-Provider AI Settings (Round-Robin)
# Supported: OpenRouter, Gemini, Groq, Mistral
# The orchestrator will cycle through these in order.
# -----------------------------------------------------------
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/owl-alpha

GEMINI_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro

GROQ_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

MISTRAL_URL=https://api.mistral.ai/v1/chat/completions
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-large-latest

# -----------------------------------------------------------
# Sender Wallet Configuration
# Base58 private key OR JSON byte array (e.g. [1,2,3,...])
# Fund with ~0.05 SOL from Solana testnet faucet:
#   https://faucet.solana.com
# -----------------------------------------------------------
SENDER_PRIVATE_KEY=your_private_key_here
